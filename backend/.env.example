# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5433/wifi_mgmt_db"

# ===========================================
# REDIS (BullMQ — antrean generate voucher batch)
# Catatan: kode hanya membaca host & port; belum mendukung password/TLS.
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# JWT — WAJIB
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ===========================================
JWT_SECRET=ganti_dengan_secret_acak_panjang
JWT_EXPIRES_IN=7d

# Login Google (opsional) — Client ID OAuth 2.0 dari Google Cloud Console.
# Dipakai memverifikasi ID token pada POST /api/auth/google. Kosong → login Google nonaktif.
GOOGLE_CLIENT_ID=

# ===========================================
# ENKRIPSI KREDENSIAL (AES-256-GCM) — WAJIB
# 64 char hex (32 byte). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PERINGATAN: generate SEKALI. Bila diganti, password router yang sudah
# tersimpan tidak bisa didekripsi lagi.
# ===========================================
MIKROTIK_ENC_KEY=

# ===========================================
# HEALTH SCHEDULER — ping periodik status router
# ===========================================
# Interval (ms) memperbarui lastStatus semua router. Default 30000.
# Set 0 (atau negatif) untuk menonaktifkan (mis. saat test/CI).
SERVER_HEALTH_INTERVAL_MS=30000
# Lama histori healthcheck disimpan (hari). Default 30.
HEALTH_RETENTION_DAYS=30

# ===========================================
# MONITORING REAL-TIME — poller terpusat + push WebSocket
# Interval (ms) poll router untuk server yang punya subscriber WebSocket.
# Default 3000 (target freshness < 5 detik). Set 0 untuk menonaktifkan poller.
# ===========================================
MONITORING_POLL_INTERVAL_MS=3000

# ===========================================
# AI / LLM — dipakai POST /ai/servers/:id/analyze & POST /ai/chat
# Isi HANYA API key provider yang dipakai.
# ===========================================
# Pilihan: gemini | openrouter | openai | anthropic (default kode: gemini)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# APP
# ===========================================
PORT=4000
NODE_ENV=development
# Asal (origin) frontend — dipakai untuk CORS REST & WebSocket monitoring.
# WAJIB diisi URL produksi saat deploy, kalau tidak request frontend kena blokir CORS.
FRONTEND_URL=http://localhost:3100

# POS — panjang kode voucher numerik (default 6)
POS_VOUCHER_CODE_LENGTH=6

# ===========================================
# DUITKU (Payment Gateway — Sandbox)
# Isi dari dashboard Duitku sandbox: https://sandbox.duitku.com
# Saat deploy, ganti callback & return URL ke domain produksi.
# ===========================================
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_BASE_URL=https://api-sandbox.duitku.com
DUITKU_CALLBACK_URL=http://localhost:4000/api/billing/duitku/callback
DUITKU_RETURN_URL=http://localhost:3100/billing/result
