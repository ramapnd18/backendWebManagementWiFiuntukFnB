# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5433/wifi_mgmt_db"

# ===========================================
# REDIS
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# JWT
# ===========================================
JWT_SECRET=ganti_dengan_secret_key_yang_panjang_dan_aman
JWT_EXPIRES_IN=7d

# ===========================================
# ENKRIPSI KREDENSIAL (AES-256-GCM) — WAJIB
# 64 char hex (32 byte). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================
MIKROTIK_ENC_KEY=

# ===========================================
# AI / LLM (Isi saat API key tersedia)
# Dipakai oleh: POST /ai/servers/:id/analyze & POST /ai/chat
# ===========================================
# Pilihan: gemini | openrouter | openai | anthropic (default kode: gemini)
LLM_PROVIDER=gemini

# Google Gemini (isi jika LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# OpenRouter (isi jika LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# OpenAI (isi jika LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic Claude (isi jika LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# ===========================================
# APP
# ===========================================
PORT=4000
NODE_ENV=development

# POS — panjang kode voucher numerik (default 6)
POS_VOUCHER_CODE_LENGTH=6

# ===========================================
# DUITKU (Payment Gateway — Sandbox)
# Isi dari dashboard sandbox: https://sandbox.duitku.com
# ===========================================
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_BASE_URL=https://sandbox.duitku.com
DUITKU_CALLBACK_URL=http://localhost:4000/api/billing/duitku/callback
DUITKU_RETURN_URL=http://localhost:3100/billing/result
